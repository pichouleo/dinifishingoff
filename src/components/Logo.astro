---
// Logo Dini Fishing — image réelle du client
interface Props {
  size?: number;
  class?: string;
}
const { size = 64, class: cls = '' } = Astro.props;
---

<img
  src="/logo.png"
  alt="Dini Fishing"
  width={size}
  height={size}
  class={cls}
  style={`width:${size}px;height:${size}px;object-fit:contain;`}
/>
