---
import type { Locale } from '../types';
import { t } from '../lib/i18n';

interface Props { locale: Locale; }
const { locale } = Astro.props;
---
<section class="bg-gradient-to-br from-[#1a1a1a] to-[#111] border-t border-b border-[var(--color-df-border)] py-16 text-center">
  <div class="df-container">
    <span class="df-label">{t(locale, 'wa_label')}</span>
    <h2 class="df-bebas text-[clamp(1.8rem,4vw,3rem)] mb-3">{t(locale, 'wa_title')}</h2>
    <p class="text-[rgba(245,240,232,0.7)] mb-7 max-w-lg mx-auto">{t(locale, 'wa_desc')}</p>
    <a
      href="https://wa.me/33668178743"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#25D366] text-white text-sm font-semibold tracking-wider uppercase rounded-sm transition-all hover:bg-[#1ebe5a] hover:-translate-y-px hover:shadow-[0_6px_24px_rgba(37,211,102,0.3)]"
    >
      {t(locale, 'wa_cta')}
    </a>
  </div>
</section>
