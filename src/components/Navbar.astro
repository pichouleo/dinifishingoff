---
import type { Locale } from '../types';
import { t } from '../lib/i18n';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;

const links = [
  { key: 'nav_home' as const,          href: '/' },
  { key: 'nav_stays' as const,         href: '/sejours' },
  { key: 'nav_accommodation' as const, href: '/hebergement' },
  { key: 'nav_species' as const,       href: '/especes' },
  { key: 'nav_gallery' as const,       href: '/galerie' },
  { key: 'nav_blog' as const,          href: '/blog' },
  { key: 'nav_contact' as const,       href: '/contact' },
];

const current = Astro.url.pathname;
---

<nav
  id="df-nav"
  class="fixed top-0 left-0 right-0 z-50 h-[72px] flex items-center transition-all duration-300"
  aria-label="Navigation principale"
>
  <div class="df-container w-full flex items-center gap-8">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0 leading-none" aria-label="Dini Fishing — Accueil">
      <span class="font-['Georgia',serif] italic text-[var(--color-df-cream)] text-[1.35rem]">Dini</span><span
        class="df-bebas text-[var(--color-df-red)] text-[1.5rem] tracking-widest ml-0.5">FISHING</span
      >
    </a>

    <!-- Desktop links -->
    <div class="hidden lg:flex items-center gap-7 ml-auto">
      {
        links.map(({ key, href }) => (
          <a
            href={href}
            class:list={[
              'text-[0.78rem] font-medium tracking-[0.1em] uppercase transition-colors duration-200 relative pb-0.5',
              'after:absolute after:bottom-[-2px] after:left-0 after:right-0 after:h-px after:bg-[var(--color-df-red)] after:scale-x-0 after:transition-transform after:duration-200',
              current === href || (href !== '/' && current.startsWith(href))
                ? 'text-[var(--color-df-cream)] after:scale-x-100'
                : 'text-[rgba(245,240,232,0.7)] hover:text-[var(--color-df-cream)] hover:after:scale-x-100',
            ]}
          >
            {t(locale, key)}
          </a>
        ))
      }
    </div>

    <!-- Actions -->
    <div class="hidden lg:flex items-center gap-4 flex-shrink-0 ml-6">
      <!-- Lang switcher -->
      <div class="flex gap-1" aria-label="Langue">
        {(['fr', 'en', 'es'] as Locale[]).map((lang) => (
          <button
            data-lang={lang}
            class:list={[
              'text-[0.72rem] font-semibold tracking-wider uppercase px-1.5 py-1 rounded-sm transition-all duration-200 cursor-pointer',
              lang === locale
                ? 'text-[var(--color-df-cream)] bg-white/10'
                : 'text-[rgba(245,240,232,0.45)] hover:text-[var(--color-df-cream)]',
            ]}
            aria-label={lang.toUpperCase()}
          >
            {lang.toUpperCase()}
          </button>
        ))}
      </div>
      <a
        href="/contact"
        class="inline-flex items-center px-6 py-3 bg-[var(--color-df-red)] text-white text-[0.8rem] font-semibold tracking-[0.06em] uppercase rounded-sm transition-all duration-200 hover:bg-[var(--color-df-red-dark)] hover:-translate-y-px hover:shadow-[0_6px_24px_rgba(192,57,43,0.4)]"
      >
        {t(locale, 'nav_book')}
      </a>
    </div>

    <!-- Burger -->
    <button
      id="df-burger"
      class="lg:hidden ml-auto flex flex-col gap-[5px] p-1 cursor-pointer"
      aria-label="Menu"
      aria-expanded="false"
    >
      <span class="block w-6 h-0.5 bg-[var(--color-df-cream)] rounded-sm transition-all duration-300"></span>
      <span class="block w-6 h-0.5 bg-[var(--color-df-cream)] rounded-sm transition-all duration-300"></span>
      <span class="block w-6 h-0.5 bg-[var(--color-df-cream)] rounded-sm transition-all duration-300"></span>
    </button>
  </div>
</nav>

<!-- Mobile menu -->
<div
  id="df-mobile-menu"
  class="fixed top-[72px] left-0 right-0 z-40 hidden flex-col gap-1 bg-[rgba(10,10,10,0.98)] backdrop-blur-lg border-t border-[var(--color-df-border)] px-6 py-6"
  role="dialog"
  aria-label="Menu mobile"
>
  {
    links.map(({ key, href }) => (
      <a
        href={href}
        class="py-3 text-[0.9rem] font-medium tracking-[0.1em] uppercase text-[rgba(245,240,232,0.8)] border-b border-[var(--color-df-border)] hover:text-[var(--color-df-cream)] transition-colors"
      >
        {t(locale, key)}
      </a>
    ))
  }
  <div class="flex gap-2 mt-4">
    {(['fr', 'en', 'es'] as Locale[]).map((lang) => (
      <button
        data-lang={lang}
        class:list={[
          'text-[0.72rem] font-semibold tracking-wider uppercase px-2 py-1.5 rounded-sm transition-all duration-200 cursor-pointer',
          lang === locale
            ? 'text-[var(--color-df-cream)] bg-white/10'
            : 'text-[rgba(245,240,232,0.45)] hover:text-[var(--color-df-cream)]',
        ]}
      >
        {lang.toUpperCase()}
      </button>
    ))}
  </div>
  <a
    href="/contact"
    class="mt-4 self-start inline-flex items-center px-6 py-3 bg-[var(--color-df-red)] text-white text-[0.8rem] font-semibold tracking-[0.06em] uppercase rounded-sm"
  >
    {t(locale, 'nav_book')}
  </a>
</div>

<script>
  const nav = document.getElementById('df-nav');
  const burger = document.getElementById('df-burger');
  const menu = document.getElementById('df-mobile-menu');

  // Scroll effect
  window.addEventListener('scroll', () => {
    if (!nav) return;
    if (window.scrollY > 40) {
      nav.classList.add('bg-[rgba(10,10,10,0.96)]', 'shadow-[0_1px_0_rgba(255,255,255,0.07)]', 'backdrop-blur-xl');
    } else {
      nav.classList.remove('bg-[rgba(10,10,10,0.96)]', 'shadow-[0_1px_0_rgba(255,255,255,0.07)]', 'backdrop-blur-xl');
    }
  }, { passive: true });

  // Burger toggle
  burger?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    menu?.classList.toggle('flex', open);
    burger.setAttribute('aria-expanded', String(open));
    const spans = burger.querySelectorAll('span');
    if (open) {
      spans[0].style.transform = 'rotate(45deg) translate(5px, 5px)';
      spans[1].style.opacity = '0';
      spans[2].style.transform = 'rotate(-45deg) translate(5px, -5px)';
    } else {
      spans.forEach(s => { s.style.transform = ''; s.style.opacity = ''; });
    }
  });

  // Close on link click
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden');
      menu.classList.remove('flex');
      burger?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
