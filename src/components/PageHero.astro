---
interface Props {
  label: string;
  title: string;
  subtitle?: string;
  bgImage: string;
  height?: string;
}
const { label, title, subtitle, bgImage, height = '420px' } = Astro.props;
---
<header class="relative flex items-end overflow-hidden" style={`height: ${height};`}>
  <div
    class="absolute inset-0 bg-cover bg-center"
    style={`background-image: url('${bgImage}'); filter: brightness(0.4);`}
  ></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[rgba(10,10,10,0.9)]"></div>
  <div class="df-container relative z-10 w-full pb-12">
    <span class="df-label">{label}</span>
    <h1 class="df-bebas text-[clamp(2.5rem,7vw,5rem)] text-white leading-none">{title}</h1>
    {subtitle && <p class="mt-3 text-[1.05rem] text-[rgba(245,240,232,0.8)] max-w-xl">{subtitle}</p>}
  </div>
</header>
