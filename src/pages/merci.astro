---
import BaseLayout from '../layouts/BaseLayout.astro';
import { t } from '../lib/i18n';
import type { Locale } from '../types';

const locale: Locale = 'fr';
---

<BaseLayout
  title="Message envoyé — Dini Fishing"
  description="Votre message a bien été envoyé. Dini vous répondra sous 24 à 48 heures."
  locale={locale}
  noindex={true}
>
  <div class="min-h-screen flex items-center justify-center text-center px-6 pt-[72px]">
    <div>
      <div class="text-6xl mb-6">🎣</div>
      <h1 class="df-bebas text-[clamp(2rem,6vw,4rem)] mb-3">{t(locale, 'merci_title')}</h1>
      <div class="w-12 h-0.5 bg-[var(--color-df-red)] mx-auto my-4"></div>
      <p class="text-[rgba(245,240,232,0.75)] max-w-md mx-auto mb-8">{t(locale, 'merci_desc')}</p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a
          href="https://wa.me/33668178743"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 bg-[#25D366] text-white text-sm font-semibold tracking-wider uppercase rounded-sm transition-all hover:bg-[#1ebe5a] hover:-translate-y-px"
        >
          {t(locale, 'merci_wa')}
        </a>
        <a
          href="/"
          class="inline-flex items-center px-8 py-3.5 border border-[rgba(245,240,232,0.35)] text-sm font-semibold tracking-wider uppercase rounded-sm transition-all hover:border-[var(--color-df-cream)] hover:bg-[rgba(245,240,232,0.06)]"
        >
          {t(locale, 'merci_back')}
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
