---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../types';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  locale?: Locale;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = 'https://images.unsplash.com/photo-1559827291-72ee739d0d9a?w=1200&q=80',
  locale = 'fr',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://dinifishing.com');
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : locale === 'en' ? 'en_GB' : 'es_ES'} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Translations JSON for client-side i18n -->
    <script type="application/json" id="df-translations" set:html={JSON.stringify(translations)} />
  </head>
  <body>
    <Navbar locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- i18n client-side switcher -->
    <script>
      type Locale = 'fr' | 'en' | 'es';
      type Dict = Record<string, string | string[]>;
      type Translations = Record<Locale, Dict>;

      function applyLang(lang: Locale) {
        const raw = document.getElementById('df-translations')?.textContent;
        if (!raw) return;
        const tr = JSON.parse(raw) as Translations;
        const dict = tr[lang] ?? tr['fr'];

        // Update all [data-i18n] elements (text content)
        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n!;
          const val = dict[key];
          if (val !== undefined) el.textContent = Array.isArray(val) ? val.join(', ') : val;
        });

        // Update all [data-i18n-html] elements (innerHTML)
        document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach((el) => {
          const key = el.dataset.i18nHtml!;
          const val = dict[key];
          if (val !== undefined) el.innerHTML = Array.isArray(val) ? val.join(', ') : val;
        });

        // Update placeholders
        document.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('[data-i18n-placeholder]').forEach((el) => {
          const key = (el as HTMLElement).dataset.i18nPlaceholder!;
          const val = dict[key];
          if (val !== undefined) (el as HTMLInputElement).placeholder = Array.isArray(val) ? val[0] : val;
        });

        // Update lang switcher buttons active state
        document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((b) => {
          const isActive = b.dataset.lang === lang;
          if (isActive) {
            b.classList.add('!bg-[var(--color-df-red)]', '!text-white');
            b.classList.remove('text-[rgba(245,240,232,0.5)]');
          } else {
            b.classList.remove('!bg-[var(--color-df-red)]', '!text-white');
            b.classList.add('text-[rgba(245,240,232,0.5)]');
          }
        });

        document.documentElement.lang = lang;
        localStorage.setItem('df_lang', lang);
      }

      document.addEventListener('DOMContentLoaded', () => {
        // Apply stored language if different from rendered locale
        const stored = localStorage.getItem('df_lang') as Locale | null;
        const current = document.documentElement.lang as Locale;
        if (stored && stored !== current) {
          applyLang(stored);
        }

        // Hook up lang buttons
        document.querySelectorAll<HTMLButtonElement>('[data-lang]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const lang = btn.dataset.lang as Locale;
            applyLang(lang);
          });
        });
      });
    </script>
  </body>
</html>
