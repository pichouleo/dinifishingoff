---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import type { Locale } from '../types';
import { translations } from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  locale?: Locale;
  noindex?: boolean;
}

const {
  title,
  description,
  ogImage = 'https://images.unsplash.com/photo-1559827291-72ee739d0d9a?w=1200&q=80',
  locale = 'fr',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://dinifishing.com');

// Sérialise les traductions pour le client — define:vars injecte ça en JS natif
const tr = translations;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : locale === 'en' ? 'en_GB' : 'es_ES'} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <Navbar locale={locale} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />

    <!-- i18n : injection des traductions via define:vars (méthode officielle Astro) -->
    <script define:vars={{ tr }}>
      function applyLang(lang) {
        var dict = tr[lang] || tr['fr'];

        // Mettre à jour tous les éléments [data-i18n]
        document.querySelectorAll('[data-i18n]').forEach(function(el) {
          var key = el.getAttribute('data-i18n');
          var val = dict[key];
          if (val !== undefined) {
            el.textContent = Array.isArray(val) ? val.join(', ') : val;
          }
        });

        // Mettre à jour les éléments [data-i18n-html] (innerHTML)
        document.querySelectorAll('[data-i18n-html]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-html');
          var val = dict[key];
          if (val !== undefined) {
            el.innerHTML = Array.isArray(val) ? val.join(', ') : val;
          }
        });

        // Mettre à jour les placeholders
        document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el) {
          var key = el.getAttribute('data-i18n-placeholder');
          var val = dict[key];
          if (val !== undefined) el.placeholder = Array.isArray(val) ? val[0] : val;
        });

        // Mettre à jour l'état actif des boutons de langue (style inline, pas Tailwind)
        document.querySelectorAll('[data-lang]').forEach(function(btn) {
          var isActive = btn.getAttribute('data-lang') === lang;
          btn.style.backgroundColor = isActive ? '#C0392B' : 'transparent';
          btn.style.color = isActive ? '#ffffff' : 'rgba(245,240,232,0.5)';
        });

        document.documentElement.lang = lang;
        localStorage.setItem('df_lang', lang);
      }

      document.addEventListener('DOMContentLoaded', function() {
        // Appliquer la langue sauvegardée si différente du rendu serveur
        var stored = localStorage.getItem('df_lang');
        var current = document.documentElement.lang;
        if (stored && stored !== current) {
          applyLang(stored);
        }

        // Brancher les boutons de langue
        document.querySelectorAll('[data-lang]').forEach(function(btn) {
          btn.addEventListener('click', function() {
            var lang = btn.getAttribute('data-lang');
            applyLang(lang);
          });
        });
      });
    </script>
  </body>
</html>
